&control
  calculation  = 'scf'
  prefix       = 'graphene'
  outdir       = './out'
  pseudo_dir   = './pseudo'
/
&system
  ibrav        = 4          ! hexagonal
  celldm(1)    = 4.661      ! a in Bohr (2.467 Ang)
  celldm(3)    = 7.634      ! c/a (vacuum ~20 Ang)
  nat          = 2
  ntyp         = 1
  ecutwfc      = 50.0
  ecutrho      = 400.0
  occupations  = 'smearing'
  smearing     = 'gaussian'
  degauss      = 0.01
/
&electrons
  conv_thr     = 1.0d-8
/
ATOMIC_SPECIES
  C  12.011  C.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS {crystal}
  C  0.000000  0.000000  0.250000
  C  0.333333  0.666667  0.250000

K_POINTS {automatic}
 12 12  1  0 0 0
