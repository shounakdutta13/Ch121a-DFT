&control
  calculation  = 'bands'
  prefix       = 'graphene'
  outdir       = './out'
  pseudo_dir   = './pseudo'
/
&system
  ibrav        = 4
  celldm(1)    = 4.661
  celldm(3)    = 7.634
  nat          = 2
  ntyp         = 1
  ecutwfc      = 50.0
  ecutrho      = 400.0
  occupations  = 'smearing'
  smearing     = 'gaussian'
  degauss      = 0.01
/
&electrons
  conv_thr     = 1.0d-8
/
ATOMIC_SPECIES
  C  12.011  C.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS {crystal}
  C  0.000000  0.000000  0.250000
  C  0.333333  0.666667  0.250000

K_POINTS {crystal_b}
4
  0.0000  0.0000  0.0  40   ! Gamma
  0.5000  0.0000  0.0  40   ! M
  0.3333  0.3333  0.0  40   ! K
  0.0000  0.0000  0.0   1   ! Gamma
