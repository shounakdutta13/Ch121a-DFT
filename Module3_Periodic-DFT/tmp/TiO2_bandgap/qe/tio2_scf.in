&control
  calculation  = 'scf'
  prefix       = 'TiO2'
  outdir       = './out'
  pseudo_dir   = './pseudo'
/
&system
  ibrav        = 6          ! tetragonal P
  celldm(1)    = 8.680      ! a in Bohr (4.594 Ang)
  celldm(3)    = 0.6442     ! c/a ratio (2.959/4.594)
  nat          = 6
  ntyp         = 2
  ecutwfc      = 50.0
  ecutrho      = 400.0
  occupations  = 'smearing'
  smearing     = 'gaussian'
  degauss      = 0.01
  ! Hubbard U on Ti d-states
  lda_plus_u        = .true.
  lda_plus_u_kind   = 0
  Hubbard_U(1)      = 4.0   ! Ti
  Hubbard_U(2)      = 0.0   ! O
/
&electrons
  conv_thr     = 1.0d-8
/
ATOMIC_SPECIES
  Ti  47.867  Ti.pbe-spn-kjpaw_psl.1.0.0.UPF
  O   15.999  O.pbe-n-kjpaw_psl.1.0.0.UPF

ATOMIC_POSITIONS {crystal}
  Ti  0.00000  0.00000  0.00000
  Ti  0.50000  0.50000  0.50000
  O   0.30490  0.30490  0.00000
  O   0.69510  0.69510  0.00000
  O   0.19510  0.80490  0.50000
  O   0.80490  0.19510  0.50000

K_POINTS {automatic}
  4 4 6  0 0 0
