
# ============================================================
# LAMMPS Input: SPC/E Water — Energy Minimization
# ============================================================
units           real
atom_style      full
boundary        p p p

read_data       water.data

# --- Force field ---
pair_style      lj/cut/coul/long 9.0 9.0
pair_coeff      1 1  0.15535 3.166   # O-O: eps(kcal/mol), sigma(Ang)
pair_coeff      1 2  0.0     0.0     # O-H: no LJ
pair_coeff      2 2  0.0     0.0     # H-H: no LJ

bond_style      harmonic
bond_coeff      1  1000.0 1.0        # stiff spring, r0=1.0 Ang

angle_style     harmonic
angle_coeff     1  1000.0 109.47     # stiff spring, theta0=109.47 deg

kspace_style    pppm 1.0e-4

# --- Constraints (rigid SPC/E bonds and angles) ---
fix             shake_water all shake 1.0e-4 20 0 b 1 a 1

# --- Neighbor list ---
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

# --- Minimization ---
log             log_min.eng
thermo          10
thermo_style    custom step temp pe press
minimize        1.0e-4 1.0e-6 1000 10000
write_data      water_min.data


# --- Nosé-Hoover NPT: T=300 K, P=1 atm ---
fix             1 all npt temp 300.0 300.0 100.0 iso 1.0 1.0 1000.0

timestep        1.0
log             npt.eng
thermo          100
thermo_style    custom step temp press density etotal ke pe evdwl ecoul vol
thermo_modify line multi

# Trajectory for analysis (every 1ps)
dump            1 all custom 1000 npt_traj.lammpstrj id element xu yu zu
dump_modify     1 sort id element O H
restart         50000 restart.npt300K.*
run             200000      # 200 ps

write_data      water_npt_final.data

unfix 1
undump 1

# --- Nosé-Hoover NVT: T=300 K ---
fix             1 all nvt temp 300.0 300.0 100.0

timestep        1.0
log             nvt.eng
thermo          100
thermo_style    custom step temp press etotal ke pe evdwl ecoul vol
thermo_modify line multi

# Trajectory for analysis (every 1ps)
dump            1 all custom 1000 nvt_traj.lammpstrj id element xu yu zu
dump 		2 all custom 1000 nvt_analysis.lammpstrj id type xu yu zu
dump_modify     1 sort id element O H
restart         50000 restart.nvt300K.*
run             200000      # 200 ps

write_data      water_nvt_final.data

