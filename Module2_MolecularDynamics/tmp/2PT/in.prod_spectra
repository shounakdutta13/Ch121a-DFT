
# ============================================================
# LAMMPS Input: SPC/E Flex_Water 
# ============================================================
units           real
atom_style      full
boundary        p p p

read_restart    restart.nvt300K.20000 
#read_data       water.data

# --- Force field ---
pair_style      lj/cut/coul/long 10.0 10.0
pair_coeff      1 1  0.15535 3.166   # O-O: eps(kcal/mol), sigma(Ang)
pair_coeff      1 2  0.0     0.0     # O-H: no LJ
pair_coeff      2 2  0.0     0.0     # H-H: no LJ

bond_style      harmonic
bond_coeff      1  553.935 1.0        # stiff spring, r0=1.0 Ang

angle_style     harmonic
angle_coeff     1  45.767 109.47     # stiff spring, theta0=109.47 deg

kspace_style    pppm 1.0e-4

# --- Constraints (rigid SPC/E bonds and angles) ---
#fix             shake_water all shake 1.0e-4 20 0 b 1 a 1

# --- Neighbor list ---
neighbor        2.0 bin
neigh_modify    every 1 delay 0 check yes

reset_timestep 0


thermo 2
 log             2pt1.300K.eng
dump                 2 all custom 2 2pt1.300K.lammps id type xu yu zu vx vy vz
#dump                 3 all custom 2 2p1t_${sname}.298K.lmp id element xu yu zu q
#dump_modify          3 sort id element H O
dump_modify          2 first yes sort id
fix             1 all nvt temp 300 300 100.0
 thermo_style    custom etotal ke temp pe ebond eangle edihed eimp evdwl ecoul elong press vol
 thermo_modify   line multi
restart 10000 checkpoints.*
 run             20000
undump          2
#undump          3
unfix           1
